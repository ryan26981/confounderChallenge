    "#| label: fig-plot-outcomes-severity\n",
    "#| fig-cap: Post-Surgical Symptom Score (lower is better) by Patient and Severity\n",
    "#| echo: false\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "import pandas as pd\n",
    "\n",
    "patients_df = pd.read_csv(\"patients_data.csv\")\n",
    "\n",
    "dreamy_color = \"#4E79A7\"\n",
    "duck_color = \"#E15759\"\n",
    "overlap_low = -1\n",
    "overlap_high = 1\n",
    "\n",
    "dreamy = patients_df[\"doctor_name\"] == \"Doc Dreamy\"\n",
    "duck = patients_df[\"doctor_name\"] == \"Doc Duck\"\n",
    "\n",
    "mean_dreamy = patients_df.loc[dreamy, \"post_surgical_score\"].mean()\n",
    "mean_duck = patients_df.loc[duck, \"post_surgical_score\"].mean()\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(9, 5), layout=\"constrained\")\n",
    "\n",
    "ax.axvspan(overlap_low, overlap_high, alpha=0.15, color=\"gray\", zorder=0)\n",
    "\n",
    "ax.scatter(\n",
    "    patients_df.loc[dreamy, \"severity\"],\n",
    "    patients_df.loc[dreamy, \"post_surgical_score\"],\n",
    "    marker=\"o\",\n",
    "    s=55,\n",
    "    facecolors=dreamy_color,\n",
    "    edgecolors=\"white\",\n",
    "    linewidths=0.6,\n",
    "    label=\"Doc Dreamy\",\n",
    "    zorder=3,\n",
    ")\n",
    "ax.scatter(\n",
    "    patients_df.loc[duck, \"severity\"],\n",
    "    patients_df.loc[duck, \"post_surgical_score\"],\n",
    "    marker=\"^\",\n",
    "    s=65,\n",
    "    facecolors=duck_color,\n",
    "    edgecolors=\"white\",\n",
    "    linewidths=0.6,\n",
    "    label=\"Doc Duck\",\n",
    "    zorder=3,\n",
    ")\n",
    "\n",
    "ax.axhline(mean_dreamy, color=dreamy_color, linestyle=\"--\", linewidth=1.5, alpha=0.9, zorder=2)\n",
    "ax.axhline(mean_duck, color=duck_color, linestyle=\"--\", linewidth=1.5, alpha=0.9, zorder=2)\n",
    "\n",
    "ax.text(\n",
    "    0.99,\n",
    "    0.97,\n",
    "    f\"Mean ○ Doc Dreamy: {mean_dreamy:.2f}\\nMean △ Doc Duck: {mean_duck:.2f}\",\n",
    "    transform=ax.transAxes,\n",
    "    ha=\"right\",\n",
    "    va=\"top\",\n",
    "    fontsize=10,\n",
    "    bbox=dict(boxstyle=\"round,pad=0.35\", facecolor=\"white\", edgecolor=\"0.75\", alpha=0.95),\n",
    ")\n",
    "\n",
    "ax.set_xlabel(\"Initial Patient Severity\", fontsize=11)\n",
    "ax.set_ylabel(\"Post-Surgical Symptom Score (Lower is Better)\", fontsize=11)\n",
    "ax.set_title(\"Post-Surgical Symptom Score by Patient Severity\", fontsize=12, pad=10)\n",
    "ax.grid(True, linestyle=\":\", linewidth=0.8, alpha=0.65)\n",
    "ax.legend(frameon=True, loc=\"lower right\", fontsize=10)\n",
    "\n",
    "ax.tick_params(axis=\"both\", labelsize=10)"
   ]
