    "#| label: load-data-python\n",
    "#| echo: false\n",
    "\n",
    "import pandas as pd\n",
    "\n",
    "# Load the observational data\n",
    "patients_df = pd.read_csv('patients_data.csv')\n",
    "\n",
    "# Display first few rows to understand the structure\n",
    "print(f\"Number of patients: {len(patients_df)}\")\n",
    "patients_df.head()"
   ]
